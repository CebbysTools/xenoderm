{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Ghidra",
      "type": "shell",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "options": {
        "env": {
          "GHIDRA_VERSION": "latest",
          "GHIDRA_PATH": "${workspaceFolder}\\.tools\\ghidra",
          "GITHUB_OUTPUT": "${workspaceFolder}\\.github\\output.env"
        }
      },
      "command": "python \"${workspaceFolder}\\scripts\\setup\\install-ghidra.py\"",
      "problemMatcher": []
    }
  ]
}